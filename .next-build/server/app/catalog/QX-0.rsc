17:["$","$L1d",null,{"data":{"sectionLabel":"Technical Data","title":"Dimensions & specifications","specs":[{"label":"Width","value":"1200 – 2000 mm"},{"label":"Depth","value":"600 – 900 mm"},{"label":"Height range (electric)","value":"650 – 1300 mm"},{"label":"Height range (manual)","value":"720 – 1180 mm"},{"label":"Load capacity","value":"80 – 120 kg"},{"label":"Weight (frame)","value":"28 – 42 kg"},{"label":"Desktop thickness","value":"25 mm"},{"label":"Adjustment speed","value":"38 mm/s"}],"certifications":["EN 527-1:2011 Office furniture — Work tables","EN 527-2:2016 Safety requirements","GS Mark (Geprüfte Sicherheit)","ISO 14001 Environmental Management"],"dimensionDiagram":{"width":"1600 mm","depth":"800 mm","heightRange":"650–1300 mm"}}}]
18:["$","$L1e",null,{"data":{"sectionLabel":"Craftsmanship","title":"Materials & finishes","materials":[{"name":"Desktop Surface","desc":"High-pressure laminate (HPL) on 25mm moisture-resistant particleboard core. Scratch-resistant, easy to clean, ABS edge banding 2mm.","specs":"EN 438 Class HGS"},{"name":"Steel Frame","desc":"Cold-rolled steel profiles, powder-coated finish in RAL colours. Anti-corrosion treated. Column profiles: 70×70mm rectangular tube.","specs":"EN 10025-2 S235JR"},{"name":"Feet & Levellers","desc":"Die-cast zinc alloy feet with felt pads for floor protection. Adjustable levellers ±15mm for uneven floors.","specs":"EN 1728 certified"}],"swatches":[{"name":"Natural Oak","hex":"#c9a96e"},{"name":"Walnut Dark","hex":"#5c3a21"},{"name":"Pure White","hex":"#f2f0ec"},{"name":"Light Grey","hex":"#c8c5be"},{"name":"Anthracite","hex":"#3a3a3c"},{"name":"Black","hex":"#1a1a1a"},{"name":"Warm Beige","hex":"#d4c5a9"},{"name":"Sage Green","hex":"#8a9a7b"}],"detailImage":"/catalogs/QX-0/materials/detail.jpg","detailImageAlt":"Close-up of QX desk showing premium oak wood grain texture and precision steel joint connection","detailImageCaption":"Detail: Natural Oak HPL surface with ABS edge banding and powder-coated steel frame"}}]
19:["$","$L1f",null,{"data":{"sectionLabel":"Functionality","title":"Features & ergonomics","items":[{"icon":"arrow-up-down","title":"Height Adjustment","desc":"Dual-motor electric system with anti-collision sensor. Smooth 38mm/s travel speed, 4 memory presets on LED touchpad. Manual crank option available for QX Basic.","badge":"Electric / Manual"},{"icon":"cable","title":"Cable Management","desc":"Integrated cable spine runs full desk length. Removable cable tray with brush grommet openings. Power socket modules available for desktop mounting.","badge":"Integrated"},{"icon":"wrench","title":"Tool-Free Assembly","desc":"Pre-assembled frame with click-lock connections. Desktop attachment with 6 screws only. Full setup in under 20 minutes by one person.","badge":"< 20 min"},{"icon":"layout-grid","title":"Modular Expansion","desc":"Add return desks, screen dividers, CPU holders, monitor arms, and under-desk storage. All accessories use universal T-slot mounting system.","badge":"30+ Accessories"},{"icon":"monitor-smartphone","title":"Smart Integration","desc":"Optional Bluetooth module connects to Metro Desk App. Track sitting/standing time, receive reminders, and sync height presets across devices.","badge":"Optional"},{"icon":"armchair","title":"Ergonomic Design","desc":"Designed with occupational therapists to promote active sitting/standing cycles. Curved front edge reduces forearm pressure. Meets EN 527 ergonomic requirements.","badge":"EN 527"}]}}]
1a:["$","$L20",null,{"data":{"sectionLabel":"Getting Started","title":"Assembly & ordering","steps":[{"step":1,"title":"Unpack frame","desc":"Remove frame components from packaging. Verify all parts against the included checklist."},{"step":2,"title":"Assemble legs","desc":"Click-lock the column tubes into the crossbar. No tools required for this step."},{"step":3,"title":"Attach feet","desc":"Screw levelling feet into column bases. Adjust for uneven floors as needed."},{"step":4,"title":"Mount desktop","desc":"Place desktop face-down on soft surface. Align frame and secure with 6 included screws."},{"step":5,"title":"Connect power","desc":"Route motor cables through cable spine. Connect control box and plug into mains power."},{"step":6,"title":"Flip & calibrate","desc":"Carefully flip desk upright. Run auto-calibration by holding ▼ button for 5 seconds."}],"orderCodes":[{"code":"QX-1200-OAK-BK","desc":"1200×600mm, Natural Oak, Black Frame"},{"code":"QX-1400-OAK-BK","desc":"1400×700mm, Natural Oak, Black Frame"},{"code":"QX-1600-OAK-BK","desc":"1600×800mm, Natural Oak, Black Frame"},{"code":"QX-1800-WAL-SL","desc":"1800×800mm, Walnut Dark, Silver Frame"},{"code":"QX-2000L-OAK-BK","desc":"2000×900mm, Natural Oak, Black Frame"}],"ctaLabels":{"quote":"Request a Quote","pdf":"Download PDF","contact":"Contact Sales"},"footerText":"© 2025 METRO. All rights reserved. Catalogue version QX-2025.1","versionInfo":"Co-financed by European Funds (PARP). All products meet WCAG 2.1 AA accessibility standards."}}]
